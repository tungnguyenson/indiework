# --- IndieWork DEMO instance ---
# Copy to `.env.demo` on the VPS (chmod 600, NOT in git). This runs the SAME image
# as the real app but against its OWN database with its OWN secrets, so the public
# demo can never reach or unlock your real workspace. See docs/infra/demo.md.

# A SEPARATE database — never the real `indiework` one. Create it once on the host:
#   sudo -u postgres createdb -O indiework indiework_demo
DATABASE_URL=postgres://indiework:<pass>@host.docker.internal:5432/indiework_demo

# Public demo admin — shown + prefilled on the login screen (see DEMO_HINT / DEMO_EMAIL).
ADMIN_EMAIL=demo@demo.local
ADMIN_PASSWORD=demo

# MUST be different from the real app's COOKIE_SECRET (>= 32 chars). This is what
# guarantees a demo session can never be replayed against app.indiework.space.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=replace-with-a-DIFFERENT-long-random-string-at-least-32-chars

# Throwaway Bearer token — the REST API (/api/v1) and MCP (/mcp) are exposed on
# the demo too. Keep it distinct from the real API_TOKEN.
API_TOKEN=demo-token

# Demo niceties, read at RUNTIME by the login page (NOT NEXT_PUBLIC_*, because one
# build serves both instances). Only set these on the demo:
DEMO_MODE=true
DEMO_HINT=demo
DEMO_EMAIL=demo@demo.local


MAILGUN_API_KEY=""
MAILGUN_DOMAIN="mail.indiework.space"
MAILGUN_FROM_EMAIL="noreply@indiework.space"
MAILGUN_FROM_NAME="IndieWork"

APP_URL=https://app.indiework.space