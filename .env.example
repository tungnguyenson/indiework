# --- IndieWork environment ---
# Copy to .env and fill in. All values are required (validated at startup).

# Postgres connection string. Use 127.0.0.1 (not localhost) on macOS to avoid
# an IPv6 (::1) resolution stall with node-postgres.
DATABASE_URL=postgres://indiework:indiework@127.0.0.1:5432/indiework

# Optional: a SEPARATE database for the integration tests (services.int.test.ts).
# Those tests run only when this is set, and against THIS db — so a bare
# `pnpm test` never writes to DATABASE_URL above. Point it at a throwaway db
# (same schema, via `pnpm db:migrate`), e.g.:
#   TEST_DATABASE_URL=postgres://indiework:indiework@127.0.0.1:5432/indiework_test

# Admin login (email + password). Seeded on first boot; used for web sign-in.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Secret used to sign the session cookie. Min 32 chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Static Bearer token for the REST API and MCP server (deprecated — prefer per-agent api_keys).
#   Authorization: Bearer <API_TOKEN>
# Back-compat: still accepted, mapped to the `default-agent` user on boot.
API_TOKEN=change-me-too

# Cloudflare R2 for attachment file storage (S3-compatible). All four must be set
# together for production. In dev/test without R2, uploads use in-memory storage.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# Deprecated — no longer used for login. Kept only for older docs referencing APP_PASSWORD.
# APP_PASSWORD=change-me

MAILGUN_API_KEY=""
MAILGUN_DOMAIN="mail.indiework.space"
MAILGUN_FROM_EMAIL="noreply@indiework.space"
MAILGUN_FROM_NAME="IndieWork"

APP_URL=https://app.indiework.space