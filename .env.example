# --- IndieWork environment ---
# Copy to .env and fill in. All values are required (validated at startup).

# Postgres connection string. Use 127.0.0.1 (not localhost) on macOS to avoid
# an IPv6 (::1) resolution stall with node-postgres.
DATABASE_URL=postgres://indiework:indiework@127.0.0.1:5432/indiework

# Web login password (single user). The /login screen compares against this.
# This one secret guards the whole app; login throttling (src/server/auth/
# rate-limit.ts) is only defense-in-depth, so make this HIGH-ENTROPY. Generate:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
APP_PASSWORD=change-me

# Secret used to sign the session cookie. Min 32 chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Static Bearer token for the REST API and MCP server.
#   Authorization: Bearer <API_TOKEN>
API_TOKEN=change-me-too
