# --- IndieWork environment ---
# Copy to .env and fill in. All values are required (validated at startup).

# Postgres connection string. Use 127.0.0.1 (not localhost) on macOS to avoid
# an IPv6 (::1) resolution stall with node-postgres.
DATABASE_URL=postgres://indiework:indiework@127.0.0.1:5432/indiework

# Admin login (email + password). Seeded on first boot; used for web sign-in.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Secret used to sign the session cookie. Min 32 chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Static Bearer token for the REST API and MCP server (deprecated — prefer per-agent api_keys).
#   Authorization: Bearer <API_TOKEN>
# Back-compat: still accepted, mapped to the `default-agent` user on boot.
API_TOKEN=change-me-too

# Deprecated — no longer used for login. Kept only for older docs referencing APP_PASSWORD.
# APP_PASSWORD=change-me
